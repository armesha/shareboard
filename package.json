{
  "name": "shareboard",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "server": "node server/index.js",
    "start": "npm run build && npm run server",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "load-test": "node tests/load/index.js",
    "load-test:10": "node tests/load/index.js 10",
    "load-test:30": "node tests/load/index.js 30",
    "load-test:50": "node tests/load/index.js 50",
    "load-test:70": "node tests/load/index.js 70",
    "load-test:100": "node tests/load/index.js 100",
    "load-test:ramp": "node tests/load/index.js ramp",
    "load-test:burst": "node tests/load/index.js burst"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "bufferutil": "^4.0.9",
    "codemirror": "^5.65.19",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fabric": "^5.4.2",
    "hotkeys-js": "^3.13.7",
    "lodash": "^4.17.21",
    "mermaid": "^11.4.1",
    "nomnoml": "^1.6.3",
    "plantuml-encoder": "^1.4.0",
    "postcss": "^8.4.24",
    "react": "^18.2.0",
    "react-codemirror2": "^8.0.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.11.2",
    "react-toastify": "^11.0.5",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "tailwindcss": "^3.3.2",
    "utf-8-validate": "^6.0.5",
    "uuid": "^11.0.3",
    "vite": "^4.3.9"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.53.3",
    "@vitest/coverage-v8": "^2.1.0",
    "concurrently": "^9.1.2",
    "vitest": "^2.1.0"
  }
}
